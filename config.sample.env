# bits Configuration

# Active provider (coingecko, binance, bitget)
BITS_PROVIDER=coingecko

# CoinGecko
BITS_COINGECKO_API_KEY=
BITS_COINGECKO_TIER=demo
BITS_COINGECKO_BASE_URL=

# Binance (shared API key for all markets)
BITS_BINANCE_API_KEY=
BITS_BINANCE_API_SECRET=
BITS_BINANCE_BASE_URL=

# Binance market-specific settings
BITS_BINANCE_SPOT_ENABLED=true
BITS_BINANCE_MARGIN_ENABLED=false
BITS_BINANCE_FUTURES_ENABLED=false
BITS_BINANCE_FUTURES_USE_TESTNET=false

# Bitget (shared API key for all markets)
BITS_BITGET_API_KEY=
BITS_BITGET_API_SECRET=
BITS_BITGET_PASSPHRASE=
BITS_BITGET_BASE_URL=

# Bitget market-specific settings
BITS_BITGET_SPOT_ENABLED=true
BITS_BITGET_FUTURES_ENABLED=false
